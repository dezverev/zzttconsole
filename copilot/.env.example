# ── Local Development ──────────────────────────────────────
# Model name (e.g., qwen/qwen3-coder-next for LM Studio, gpt-5.4-mini for OpenAI)
COPILOT_MODEL=qwen/qwen3-coder-next

# OpenAI-compatible endpoint
OPENAI_BASE_URL=http://localhost:1234/v1

# API key (not needed for LM Studio, required for OpenAI)
# OPENAI_API_KEY=sk-...

# Server port
PORT=8080
